// `match` or-patterns: A | B | C.
const { assert } = import("test");

fn twoAlternatives(x: u8) u8 {
    var r: u8 = 0;
    match (x) {
        1 | 2 { r = 100; }
        _ { r = 0; }
    }
    return r;
}

fn manyAlternatives(x: u8) u8 {
    var r: u8 = 0;
    match (x) {
        1 | 3 | 5 | 7 | 9     { r = 1; } // odd 1..9
        2 | 4 | 6 | 8         { r = 2; } // even 2..8
        _                  { r = 0; }
    }
    return r;
}

fn orOrderInsensitive(x: u8) u8 {
    // Same set of values in different orders should yield the same result.
    var r: u8 = 0;
    match (x) {
        9 | 7 | 5 | 3 | 1 { r = 42; }
        _              { r = 0; }
    }
    return r;
}

fn orFirstMatchWins(x: u8) u8 {
    var r: u8 = 0;
    match (x) {
        1 | 2 | 3 { r = 10; }
        2 | 3 | 4 { r = 20; }    // unreachable for x in {2,3} — first arm wins
        _      { r = 0; }
    }
    return r;
}

tfn twoAltOne()           { assert(twoAlternatives(1), 100); }
tfn twoAltTwo()           { assert(twoAlternatives(2), 100); }
tfn twoAltMiss()           { assert(twoAlternatives(3), 0); }

tfn manyAltOdd1()         { assert(manyAlternatives(1), 1); }
tfn manyAltOdd3()         { assert(manyAlternatives(3), 1); }
tfn manyAltOdd9()         { assert(manyAlternatives(9), 1); }
tfn manyAltEven2()        { assert(manyAlternatives(2), 2); }
tfn manyAltEven6()        { assert(manyAlternatives(6), 2); }
tfn manyAltEven8()        { assert(manyAlternatives(8), 2); }
tfn manyAltMiss10()       { assert(manyAlternatives(10), 0); }
tfn manyAltMiss0()        { assert(manyAlternatives(0), 0); }

tfn orOrderInsensitive1() { assert(orOrderInsensitive(1), 42); }
tfn orOrderInsensitive5() { assert(orOrderInsensitive(5), 42); }
tfn orOrderInsensitive9() { assert(orOrderInsensitive(9), 42); }
tfn orOrderInsensitiveMiss() { assert(orOrderInsensitive(2), 0); }

tfn orFirstWinsOne()      { assert(orFirstMatchWins(1), 10); }
tfn orFirstWinsTwo()      { assert(orFirstMatchWins(2), 10); } // not 20
tfn orFirstWinsThree()    { assert(orFirstMatchWins(3), 10); } // not 20
tfn orFirstWinsFour()     { assert(orFirstMatchWins(4), 20); } // only arm 2 covers 4
