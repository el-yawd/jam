// Test std.fmt module
const std = import("std");

fn main() u8 {
    // Test println
    std.fmt.println("Testing std.fmt.println");

    // Test print (no newline)
    std.fmt.print("Testing ");
    std.fmt.print("std.fmt.print");
    std.fmt.println("");

    // Test with different strings
    std.fmt.println("Hello, world!");
    std.fmt.println("Special chars: !@#$%");

    return 0;
}
