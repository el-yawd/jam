// Test escape sequences in strings
const std = import("std");

fn main() u8 {
    // Test basic escapes
    std.fmt.println("Tab:\ttest");
    std.fmt.println("Newline embedded:\nline2");
    std.fmt.println("Quote: \"hello\"");
    std.fmt.println("Backslash: \\path");

    // Test hex escapes (ANSI escape codes)
    std.fmt.print("\x1b[31m");  // red color
    std.fmt.println("This should be red");
    std.fmt.print("\x1b[0m");   // reset
    std.fmt.println("Back to normal");

    // Test clear screen codes (don't actually clear for this test)
    // \x1b[2J = clear screen, \x1b[H = cursor home

    return 0;
}
