// `match` integration with control flow: return, break, continue,
// nested matches, matches inside loops.
const { assert } = import("test");

fn matchWithReturn(x: u8) u8 {
    match (x) {
        0          { return 100; }
        1..=9      { return 200; }
        _       { return 255; }
    }
    return 99; // unreachable; every arm returns
}

fn matchSetsThenContinues(x: u8) u8 {
    var r: u8 = 0;
    match (x) {
        1 { r = 10; }
        2 { r = 20; }
        _ { r = 99; }
    }
    return r * 2;
}

fn nestedMatch(a: u8, b: u8) u8 {
    var r: u8 = 0;
    match (a) {
        0 {
            match (b) {
                0 { r = 1; }
                1 { r = 2; }
                _ { r = 3; }
            }
        }
        1 {
            match (b) {
                0 { r = 4; }
                _ { r = 5; }
            }
        }
        _ { r = 99; }
    }
    return r;
}

fn matchInsideWhile(start: u8) u8 {
    var i: u8 = start;
    var sum: u8 = 0;
    while (i < 5) {
        match (i) {
            0 | 2 | 4 { sum = sum + 1; }   // even: count
            _      { sum = sum + 10; }  // odd: bigger contribution
        }
        i = i + 1;
    }
    return sum;
}

fn matchInsideFor() u8 {
    var sum: u8 = 0;
    for i in 0:10 {
        match (i) {
            0..=4 { sum = sum + 1; }
            _  { sum = sum + 2; }
        }
    }
    return sum;
}

fn matchBreak(start: u8) u8 {
    var i: u8 = start;
    while (i < 100) {
        match (i) {
            42 { break; }
            _ { i = i + 1; }
        }
    }
    return i;
}

tfn matchReturnZero()     { assert(matchWithReturn(0), 100); }
tfn matchReturnOne()      { assert(matchWithReturn(1), 200); }
tfn matchReturnNine()     { assert(matchWithReturn(9), 200); }
tfn matchReturnElse()     { assert(matchWithReturn(50), 255); }

tfn matchContinue1()      { assert(matchSetsThenContinues(1), 20); }
tfn matchContinue2()      { assert(matchSetsThenContinues(2), 40); }
tfn matchContinueElse()   { assert(matchSetsThenContinues(99), 198); }

tfn nestedAA()            { assert(nestedMatch(0, 0), 1); }
tfn nestedAB()            { assert(nestedMatch(0, 1), 2); }
tfn nestedAC()            { assert(nestedMatch(0, 9), 3); }
tfn nestedBA()            { assert(nestedMatch(1, 0), 4); }
tfn nestedBB()            { assert(nestedMatch(1, 9), 5); }
tfn nestedC()             { assert(nestedMatch(9, 9), 99); }

// even count = 3 (0,2,4); odd count = 2 (1,3); total = 3*1 + 2*10 = 23.
tfn matchInWhile()        { assert(matchInsideWhile(0), 23); }
// 0..=4 is 5 ones; 5..=9 is 5 twos; total = 5 + 10 = 15.
tfn matchInFor()          { assert(matchInsideFor(), 15); }

tfn matchBreakAt42()      { assert(matchBreak(0), 42); }
