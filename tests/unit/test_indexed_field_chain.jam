const { assert } = import("test");

const Cpu = struct {
    pc: u32,
    sp: u32,
};

const Inner = struct {
    a: u32,
    b: u32,
};

const Outer = struct {
    inner: Inner,
    tag: u32,
};

const Board = struct {
    cells: [4]Cpu,
};

tfn writeArrayElemField() {
    var arr: [2]Cpu = [{ pc: 0, sp: 0 }; 2];
    arr[0].pc = 42;
    arr[1].pc = 99;
    arr[1].sp = 7;
    assert(arr[0].pc, 42);
    assert(arr[1].pc, 99);
    assert(arr[1].sp, 7);
}

tfn writeArrayElemNestedField() {
    var arr: [2]Outer = [{ inner: { a: 0, b: 0 }, tag: 0 }; 2];
    arr[0].inner.a = 10;
    arr[0].inner.b = 20;
    arr[0].tag = 1;
    arr[1].inner.a = 30;
    arr[1].tag = 2;
    assert(arr[0].inner.a, 10);
    assert(arr[0].inner.b, 20);
    assert(arr[0].tag, 1);
    assert(arr[1].inner.a, 30);
    assert(arr[1].tag, 2);
}

tfn writeIndexedFieldThroughStruct() {
    var b: Board = { cells: [{ pc: 0, sp: 0 }; 4] };
    b.cells[0].pc = 100;
    b.cells[2].sp = 200;
    b.cells[3].pc = 300;
    assert(b.cells[0].pc, 100);
    assert(b.cells[2].sp, 200);
    assert(b.cells[3].pc, 300);
}

tfn readArrayElemFieldDirectly() {
    var arr: [3]Cpu = [{ pc: 0, sp: 0 }; 3];
    arr[1].pc = 77;
    var x: u32 = arr[1].pc;
    assert(x, 77);
}

tfn computeWithIndexedField() {
    var arr: [2]Cpu = [{ pc: 5, sp: 0 }; 2];
    arr[0].pc = 5;
    arr[1].pc = 10;
    var sum: u32 = arr[0].pc + arr[1].pc;
    assert(sum, 15);
}

tfn indexExpressionWithSideEffectArith() {
    var arr: [4]Cpu = [{ pc: 0, sp: 0 }; 4];
    var i: u64 = 0;
    arr[i + 2].pc = 88;
    assert(arr[2].pc, 88);
}

fn CounterFactory(T: type) type {
    return struct {
        v: T,

        fn bump(self: mut Self, by: T) {
            self.v = self.v + by;
        }

        fn read(self: Self) T {
            return self.v;
        }
    };
}

const CounterU32 = CounterFactory(u32);

tfn methodCallOnIndexedReceiverMut() {
    var arr: [3]CounterU32 = [{ v: 0 }; 3];
    arr[0].bump(10);
    arr[1].bump(20);
    arr[2].bump(30);
    assert(arr[0].v, 10);
    assert(arr[1].v, 20);
    assert(arr[2].v, 30);
}

tfn methodCallOnIndexedReceiverLet() {
    var arr: [2]CounterU32 = [{ v: 5 }; 2];
    arr[0].bump(3);
    arr[1].bump(7);
    assert(arr[0].read(), 8);
    assert(arr[1].read(), 12);
}

tfn methodCallOnIndexedReceiverChained() {
    var arr: [2]CounterU32 = [{ v: 1 }; 2];
    arr[0].bump(arr[1].read() + 9);
    assert(arr[0].read(), 11);
}
